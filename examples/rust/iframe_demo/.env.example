# Mirror examples/python/.env.iframe — copy values from your deployment.

AUTH_PUBLIC_ORIGIN=http://localhost:8080
AUTH_API_BASE=http://127.0.0.1:8080

TENANT_ID=00000000-0000-0000-0000-000000000000

# Confidential demo (iframe-client-9999)
CLIENT_9999_ID=
CLIENT_9999_SECRET=
JWT_AUDIENCE_9999=
DEMO_PORT_9999=9999

# Public demo (iframe-client-9898)
CLIENT_9898_ID=
JWT_AUDIENCE_9898=
DEMO_PORT_9898=9898

SQLITE_PATH=iframe_demo_rust.sqlite3

# authservice-sdk: optional override (defaults to http://127.0.0.1:<demo_port>/oauth/callback)
# REDIRECT_URL=http://127.0.0.1:9999/oauth/callback

# Optional bind (default 127.0.0.1)
# DEMO_BIND=0.0.0.0
