# Copy to .env.iframe and `export $(grep -v '^#' .env.iframe | xargs)` before running demos,
# or set variables in your shell.

# Browser-visible auth URL (must match embedded_parent_origins + postMessage origin check)
AUTH_PUBLIC_ORIGIN=http://localhost:8080
# Server-side HTTP base (avoid 0.0.0.0 in Python requests on some OS)
AUTH_API_BASE=http://127.0.0.1:8080

TENANT_ID=8cdc85d6-91c6-47e4-9670-9c2b66d3a9bd

# Public client (9898)
CLIENT_9898_ID=ZBmhvliMrs

# Confidential client (9999)
CLIENT_9999_ID=DcmQebQhq1
CLIENT_9999_SECRET=74deb119-253a-44af-b0e9-a5840e6c81c29f68a670-3331-4903-beae-9dbef67ad3eb

# Must match the OAuth client's "embedded token audience" in admin (often the same string as client_id).
JWT_AUDIENCE_9898=ZBmhvliMrs
JWT_AUDIENCE_9999=DcmQebQhq1

SQLITE_PATH=iframe_demo.sqlite3
FLASK_SECRET_KEY=7cbc4ee2-4e4d-4e2c-bd4e-124cc2914612

# Optional: bind demos on all interfaces (default 127.0.0.1)
# DEMO_BIND=0.0.0.0
