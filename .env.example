SERVER__HOST=0.0.0.0
SERVER__PORT=8080
SERVER__ISSUER=http://localhost:8080
# Comma-separated origins; empty = deny cross-origin (same-origin + non-browser only)
# Example: CORS__ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS__ALLOWED_ORIGINS=

DATABASE__URL=postgres://auth:auth@localhost:5432/auth
DATABASE__POOL_SIZE=20

REDIS__URL=redis://127.0.0.1:6379

# RSA PEM (generate locally; do NOT use example keys in production)
# AUTH__JWT_PRIVATE_KEY_PEM=REPLACE_WITH_OPENSSL_OUTPUT_ONE_LINE
# AUTH__JWT_PUBLIC_KEY_PEM=REPLACE_WITH_OPENSSL_PUBKEY_ONE_LINE
# Optional: during JWT key rotation, keep verifying tokens signed with the old key (JWKS publishes both).
# AUTH__JWT_PREVIOUS_PUBLIC_KEY_PEM=REPLACE_WITH_OLD_PUBKEY_ONE_LINE
# AUTH__JWT_PREVIOUS_KID=rsa-key-0
AUTH__ACCESS_TTL_SECONDS=900
AUTH__REFRESH_TTL_SECONDS=1209600
# HMAC/secret for idp session cookie (>= 32 bytes; e.g. openssl rand -hex 32)
AUTH__COOKIE_SECRET=REPLACE_WITH_RANDOM_64_HEX
# Access tokens for /admin/* must have this `aud` claim (match dashboard VITE / login audience)
AUTH__ADMIN_API_AUDIENCE=auth-service
# When true, every user must enroll TOTP before password login succeeds
AUTH__REQUIRE_LOGIN_2FA=false
# Comma-separated user UUIDs: full server-wide admin lists/metrics (all tenants), not only JWT tenant
# Example: AUTH__GLOBAL_ADMIN_USER_IDS=4d2479f7-1b24-43f6-9dff-ab3a63dfc680
AUTH__GLOBAL_ADMIN_USER_IDS=7cbc4ee2-4e4d-4e2c-bd4e-124cc2914612
# Optional second list, same effect as above (e.g. separate ops allowlist)
# AUTH__AUTH_SERVICE_DEPLOYMENT_ADMINS=
# `.env` path for dashboard PUT /admin/settings (default .env in process working directory)
AUTH__ENV_FILE_PATH=.env
# Embedded iframe login (/embedded-login, /api/login): include 'self' in CSP frame-ancestors (default true)
# AUTH__EMBEDDED_CSP_INCLUDE_SELF=true
# Dev-only: skip Referer/Origin check against embedded_parent_origins
# AUTH__EMBEDDED_RELAX_PARENT_ORIGIN_CHECK=false
# Redis rate limit for POST /api/login per IP (0 = disable)
# AUTH__EMBEDDED_LOGIN_IP_MAX_ATTEMPTS=60
# AUTH__EMBEDDED_LOGIN_IP_WINDOW_SECONDS=300
# Deprecated OAuth2 password grant on POST /token (default false)
# AUTH__ALLOW_RESOURCE_OWNER_PASSWORD_GRANT=false
# Redis IP rate limits for POST /token and GET /authorize (0 = disable; /token fails closed if Redis errors when >0)
# AUTH__OAUTH_TOKEN_IP_MAX_ATTEMPTS=120
# AUTH__OAUTH_TOKEN_IP_WINDOW_SECONDS=60
# AUTH__OAUTH_AUTHORIZE_IP_MAX_ATTEMPTS=240
# AUTH__OAUTH_AUTHORIZE_IP_WINDOW_SECONDS=60
# POST /auth/register accepts only admin API JWTs (AUTH__ADMIN_API_AUDIENCE + admin role).
# End-user self-registration: /embedded-login + POST /api/register* when the client allows it.

OIDC__KEYCLOAK_CLIENT_ID=auth-service
OIDC__KEYCLOAK_CLIENT_SECRET=replace_me
# When true (default), enforce per-client TOTP on OIDC /authorize and login when policy is required
OIDC__CLIENT_MFA_ENFORCE=true
OIDC__REDIRECT_URL=http://localhost:8080/callback
# Optional: browser redirect for unauthenticated /authorize (e.g. dashboard login)
OIDC__LOGIN_URL=
OIDC__SERVER_METADATA_URL=

# Optional: if set, GET /metrics requires Authorization: Bearer <token>
# METRICS__BYPASS_TOKEN=

EMAIL__API_KEY_SECRET=

# 32 bytes base64: openssl rand -base64 32
TOTP__ENCRYPTION_KEY_B64=REPLACE_WITH_base64_32_bytes
# Optional previous key (same format) so existing sealed TOTP secrets still decrypt after rotation.
# TOTP__ENCRYPTION_KEY_PREVIOUS_B64=

VITE_APP_NAME=Auth Admin
VITE_API_BASE_URL=http://localhost:8080
VITE_SSE_URL=http://localhost:8080/events
VITE_DEFAULT_AUDIENCE=auth-service
VITE_ENV_NAME=dev
# true = request idp_session cookie for OIDC /authorize (needs AUTH__COOKIE_SECRET on API)
VITE_SET_IDP_SESSION=false
